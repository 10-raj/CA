library ieee;
use ieee.std_logic_1164.all;

entity EVEN_PARITY_raj is
    port(
        A : in std_logic_vector(3 downto 0);
        EVEN_PARITY : out std_logic
    );
end entity EVEN_PARITY_raj;

architecture behavioral of EVEN_PARITY_raj is
begin
    process(A)
    begin
        EVEN_PARITY <= A(3) xor A(2) xor A(1) xor A(0);
    end process;
end behavioral;
